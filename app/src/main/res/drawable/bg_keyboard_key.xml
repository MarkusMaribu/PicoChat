<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/ds_teal_border" />
            <stroke
                android:width="1dp"
                android:color="@color/ds_key_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ds_key_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/ds_key_border" />
        </shape>
    </item>
</selector>
