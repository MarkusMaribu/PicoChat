<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base white fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ds_white" />
            <padding
                android:left="@dimen/ds_padding_medium"
                android:top="@dimen/ds_padding_small"
                android:right="@dimen/ds_padding_medium"
                android:bottom="@dimen/ds_padding_small" />
        </shape>
    </item>
    <!-- Teal bracket border (thick) -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="3dp"
                android:color="@color/ds_teal_border" />
        </shape>
    </item>
</layer-list>
