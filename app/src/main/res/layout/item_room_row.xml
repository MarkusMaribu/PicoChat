<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="1dp"
    android:background="@drawable/bg_room_row"
    android:padding="3dp">

    <com.markusmaribu.picochat.ui.OutlinedTextView
        android:id="@+id/roomLetterIcon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="10sp"
        android:autoSizeMaxTextSize="30sp"
        android:background="@drawable/bg_room_letter_box"
        android:fontFamily="@font/press_start_2p"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="@color/ds_canvas_white"
        app:outlineColor="#FF303030"
        app:outlineWidth="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="A" />

    <!-- Room label -->
    <TextView
        android:id="@+id/roomLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="10sp"
        android:autoSizeMaxTextSize="18sp"
        android:fontFamily="@font/cozette_vector"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:textColor="@color/ds_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/userIcon"
        app:layout_constraintStart_toEndOf="@id/roomLetterIcon"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="6dp"
        tools:text="Chat Room A" />

    <!-- User icon -->
    <ImageView
        android:id="@+id/userIcon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_user_count"
        app:layout_constraintBottom_toBottomOf="@id/roomCount"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@id/roomCount"
        app:layout_constraintTop_toTopOf="@id/roomCount"
        android:layout_marginEnd="3dp" />

    <!-- User count in bordered box -->
    <TextView
        android:id="@+id/roomCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_room_count_box"
        android:fontFamily="@font/cozette_vector"
        android:textColor="@color/ds_black"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="9sp"
        android:autoSizeMaxTextSize="15sp"
        android:maxLines="1"
        android:minEms="3"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="2dp"
        tools:text="0/16" />

</androidx.constraintlayout.widget.ConstraintLayout>
